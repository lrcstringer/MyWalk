rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper functions ──────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isCircleMember(circleId) {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/circles/$(circleId)/members/$(request.auth.uid));
    }

    function isCircleAdmin(circleId) {
      return isSignedIn() &&
        get(/databases/$(database)/documents/circles/$(circleId)/members/$(request.auth.uid)).data.role == 'admin';
    }

    // ─── users ────────────────────────────────────────────────────────────
    match /users/{userId} {
      // Profile doc: owner read/write. Subscription field must never be set by client.
      allow read: if isOwner(userId);
      allow write: if isOwner(userId)
                   && !('subscription' in request.resource.data);

      // ── habits subcollection ──────────────────────────────────────────
      match /habits/{habitId} {
        allow read, write: if isOwner(userId);

        match /entries/{entryId} {
          allow read, write: if isOwner(userId);
        }
      }

      // ── user preferences (synced from all devices via FirestoreUserPreferencesRepository) ──
      match /state/{docId} {
        allow read, write: if isOwner(userId);
      }

      // ── subscription (server-write only via Admin SDK / Cloud Functions) ──
      match /subscription/{docId} {
        allow read:  if isOwner(userId);
        allow write: if false; // All writes come from validateReceipt / webhook Functions
      }

      // ── fruit_portfolio subcollection ──────────────────────────────────────
      match /fruit_portfolio/{fruitId} {
        allow read, write: if isOwner(userId);
      }

      // ── journal subcollection ─────────────────────────────────────────────
      match /journal/{entryId} {
        allow read, write: if isOwner(userId);
      }

      // ── notifications subcollection ───────────────────────────────────────
      // Written exclusively by Cloud Functions (Admin SDK / tRPC server).
      // Owner may read and update isRead / actionTaken — no creates or deletes.
      match /notifications/{notifId} {
        allow read: if isOwner(userId);
        // Allow only isRead and actionTaken to be updated by the owner.
        allow update: if isOwner(userId)
                      && request.resource.data.diff(resource.data)
                           .affectedKeys()
                           .hasOnly(['isRead', 'actionTaken']);
        allow create, delete: if false; // Admin SDK only
      }
    }

    // ─── inviteCodes ──────────────────────────────────────────────────────
    // Public read for the join flow. All writes go through Admin SDK.
    match /inviteCodes/{code} {
      allow read: if true;
      allow write: if false;
    }

    // ─── purchaseTokens ───────────────────────────────────────────────────
    // Reverse-lookup index mapping Google Play purchase tokens → Firebase UIDs.
    // Written exclusively by validateReceipt / googleNotification via Admin SDK.
    // No client access permitted — this mapping is sensitive.
    match /purchaseTokens/{tokenId} {
      allow read, write: if false;
    }

    // ─── collectionGroup: members ─────────────────────────────────────────
    // Allows listCircles() to query collectionGroup('members').where('userId', ==, uid).
    // Rule must check the userId FIELD (not the document ID) so Firestore can validate
    // the query filter — checking the doc ID would cause PERMISSION_DENIED on the query.
    match /{path=**}/members/{memberId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // ─── circles ──────────────────────────────────────────────────────────
    match /circles/{circleId} {
      allow read: if isCircleMember(circleId);
      allow create: if isSignedIn();
      allow update: if isCircleAdmin(circleId);
      allow delete: if false;

      // members subcollection
      match /members/{userId} {
        allow read: if isCircleMember(circleId);
        allow write: if false; // Admin SDK only
      }

      // gratitudes subcollection
      match /gratitudes/{gratitudeId} {
        allow read: if isCircleMember(circleId);
        // Owner can only flip deleted=true, nothing else
        allow update: if isCircleMember(circleId) &&
                         resource.data.userId == request.auth.uid &&
                         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['deleted']) &&
                         request.resource.data.deleted == true;
        allow create, delete: if false;
      }

      // heatmapEntries subcollection — owner writes, any member reads
      match /heatmapEntries/{userId} {
        allow read: if isCircleMember(circleId);
        allow write: if isOwner(userId) && isCircleMember(circleId);
      }

      // milestones — backend Admin SDK writes only
      match /milestones/{milestoneId} {
        allow read: if isCircleMember(circleId);
        allow write: if false;
      }

      // meta/totals aggregate — backend writes only
      match /meta/{docId} {
        allow read: if isCircleMember(circleId);
        allow write: if false;
      }

      // userSeenGratitude — owner read/write
      match /userSeenGratitude/{userId} {
        allow read, write: if isOwner(userId) && isCircleMember(circleId);
      }

      // prayer_requests — any member can read; all writes via callable (Admin SDK)
      match /prayer_requests/{requestId} {
        allow read: if isCircleMember(circleId);
        allow write: if false;
      }

      // scripture_threads — members read/create; admin closes and deletes
      match /scripture_threads/{threadId} {
        allow read: if isCircleMember(circleId);
        allow create: if isCircleMember(circleId);
        allow update: if isCircleAdmin(circleId); // close (status + closedAt)
        allow delete: if isCircleAdmin(circleId); // hard-delete via deleteThread batch

        // comments subcollection — members read/create; soft-delete by owner or admin
        match /comments/{commentId} {
          allow read: if isCircleMember(circleId);
          allow create: if isCircleMember(circleId);
          allow update: if isCircleMember(circleId) &&
                           (request.auth.uid == resource.data.authorId ||
                            isCircleAdmin(circleId)) &&
                           request.resource.data.diff(resource.data)
                             .affectedKeys().hasOnly(['deletedAt']);
          allow delete: if isCircleAdmin(circleId); // hard-delete via deleteThread batch
        }
      }

      // circle_habits — any member can read; create/deactivate via callable
      match /circle_habits/{habitId} {
        allow read: if isCircleMember(circleId);
        allow write: if false;

        // completions — members write their own; any member reads (for aggregation trigger)
        match /completions/{completionId} {
          allow read: if isCircleMember(circleId);
          // Completion ID is deterministic: {userId}_{date}. Client writes their own only.
          allow create: if isCircleMember(circleId) &&
                          request.resource.data.userId == request.auth.uid;
          allow update, delete: if false;
        }

        // daily_summary — any member can read; trigger writes via Admin SDK
        match /daily_summary/{summaryId} {
          allow read: if isCircleMember(circleId);
          allow write: if false;
        }
      }

      // encouragements — recipient reads via callable (privacy masking); writes via callable
      match /encouragements/{encouragementId} {
        allow read: if false; // Always fetched through circleGetEncouragements callable
        allow write: if false;
      }

      // milestone_shares — any member can read; writes via callable
      match /milestone_shares/{shareId} {
        allow read: if isCircleMember(circleId);
        allow write: if false;
      }

      // circle_habit_milestones — auto-generated by trigger; members read only
      match /circle_habit_milestones/{milestoneId} {
        allow read: if isCircleMember(circleId);
        allow write: if false;
      }

      // weekly_pulse — any member can read; writes via callable
      match /weekly_pulse/{weekId} {
        allow read: if isCircleMember(circleId);
        allow write: if false;

        // pulse responses — any member reads via callable (privacy masking); writes via callable
        match /responses/{responseId} {
          allow read: if false; // Always fetched through circleGetPulseResponses callable
          allow write: if false;
        }
      }

      // events — any member can read; create/delete via callable
      match /events/{eventId} {
        allow read: if isCircleMember(circleId);
        allow write: if false;
      }
    }

    // ─── memorizations ────────────────────────────────────────────────────
    match /users/{userId}/memorizations/{itemId} {
      allow read, write: if isOwner(userId);

      // Shared read: a friend the item was shared with can view it.
      allow read: if isSignedIn() &&
        exists(/databases/$(database)/documents/users/$(userId)/memorizations/$(itemId)/shares/$(request.auth.uid));

      match /attempts/{attemptId} {
        allow read, write: if isOwner(userId);
      }

      match /shares/{shareId} {
        allow read: if isOwner(userId) || request.auth.uid == shareId;
        allow write: if isOwner(userId);
      }
    }

    // ─── memorizationCircles ───────────────────────────────────────────────
    match /memorizationCircles/{circleId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (
        !exists(/databases/$(database)/documents/memorizationCircles/$(circleId)) ||
        request.auth.uid == resource.data.createdBy ||
        request.auth.uid in resource.data.memberIds
      );

      // Comments: any circle member can read and post; no editing/deleting others' posts.
      match /comments/{commentId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && request.resource.data.authorUid == request.auth.uid;
        allow update, delete: if request.auth.uid == resource.data.authorUid;
      }
    }

    // ─── bible_passage_cache ───────────────────────────────────────────────
    // Populated by circleFetchBiblePassage callable. Read-only for all
    // authenticated users (public scripture text, no PII).
    match /bible_passage_cache/{cacheKey} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // ─── accountability_partnerships ──────────────────────────────────────
    match /accountability_partnerships/{partnershipId} {
      // Participants can always read; non-participants can read pending invites
      // so the accepting partner can load the doc by token before partnerId is set.
      allow read: if isSignedIn() && (
        request.auth.uid in resource.data.participantIds ||
        resource.data.status == 'pending'
      );
      allow create: if false; // Cloud Function (Admin SDK) only
      // Participants may only update: status (cancel/end) or lastMessage fields (sendMessage).
      allow update: if isSignedIn() &&
        request.auth.uid in resource.data.participantIds &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['status', 'lastMessagePreview', 'lastMessageAt']);
      allow delete: if false;

      // partner_messages subcollection
      match /partner_messages/{messageId} {
        // Only participants of the parent partnership can read messages.
        allow read: if isSignedIn() &&
          request.auth.uid in get(/databases/$(database)/documents/accountability_partnerships/$(partnershipId)).data.participantIds;
        // Participants may create messages as themselves.
        allow create: if isSignedIn() &&
          request.resource.data.senderId == request.auth.uid &&
          request.auth.uid in get(/databases/$(database)/documents/accountability_partnerships/$(partnershipId)).data.participantIds;
        // Participants may mark messages read (isRead only).
        allow update: if isSignedIn() &&
          request.auth.uid in get(/databases/$(database)/documents/accountability_partnerships/$(partnershipId)).data.participantIds &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead']);
        allow delete: if false;
      }
    }

    // ─── recovery_paths ───────────────────────────────────────────────────
    // Doc ID = habitId. Only the habit owner can read/write their path.
    match /recovery_paths/{habitId} {
      allow read: if isSignedIn() &&
        (resource == null || resource.data.userId == request.auth.uid);
      allow update: if isSignedIn() &&
        resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() &&
        request.resource.data.userId == request.auth.uid;
      allow delete: if false;

      // recovery_sessions subcollection — owner only; no delete.
      match /recovery_sessions/{sessionId} {
        allow read, create, update: if isSignedIn() &&
          get(/databases/$(database)/documents/recovery_paths/$(habitId)).data.userId == request.auth.uid;
        allow delete: if false;
      }
    }

    // ─── habit_categories / habit_subcategories ────────────────────────────
    // Static data seeded by seedHabitCategories Cloud Function (admin-only).
    // Read-only for authenticated users; no client writes permitted.
    match /habit_categories/{docId} {
      allow read: if isSignedIn();
      allow write: if false;
    }
    match /habit_subcategories/{docId} {
      allow read: if isSignedIn();
      allow write: if false;
    }
  }
}
